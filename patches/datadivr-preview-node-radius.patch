+            if (!group || !group["name"] || !group["labelcolor"]) {
+                continue;
+            }
+            if ("layoutname" in group && group["layoutname"] !== selectedLayoutName) {
+                continue;
+            }
+            const colorKey = group["labelcolor"].slice(0, 3).join(",");
+            const uniqueKey = colorKey + "::" + group["name"];
+            if (seen[uniqueKey]) {
+                continue;
+            }
+            seen[uniqueKey] = true;
+            namedGroups.push({"name": group["name"], "labelcolor": group["labelcolor"]});
+        }
+        return namedGroups;
